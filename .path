#!/bin/sh
if [ -d "$HOME/bin" ]; then
	export PATH="$HOME/bin:$PATH"
fi

PATH="$PATH:$HOME/.local/bin"

# SM-A315G's default `adb shell` `PATH`
PATH="$PATH:/product/bin:/apex/com.android.runtime/bin:/apex/com.android.art/bin:/system_ext/bin:/system/bin:/system/xbin:/odm/bin:/vendor/bin:/vendor/xbin"
