#!/usr/bin/env bash

# I don't even use this, but I keep it just-in-case
if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]
then
	debian_chroot=$(cat /etc/debian_chroot)
fi

prompt_git() {
	local s=''
	local branch_name=''

	git rev-parse --is-inside-work-tree &>/dev/null || return

	# If HEAD isn’t a symbolic ref, get a tracking remote branch or tag.
	# Otherwise, get the short SHA for the latest commit, or give up.
	branch_name="$(git symbolic-ref --quiet --short HEAD 2> /dev/null || \
		git describe --all --exact-match HEAD 2> /dev/null || \
		git rev-parse --short HEAD 2> /dev/null || \
		echo '(?)')"

	# uncommitted
	if ! $(git diff --quiet --ignore-submodules --cached); then
		s+='+'
	fi
	# unstaged
	if ! $(git diff-files --quiet --ignore-submodules --); then
		s+='!'
	fi
	# untracked
	if [ -n "$(git ls-files --others --exclude-standard)" ]; then
		s+='?'
	fi
	# stashed
	if $(git rev-parse --verify refs/stash &>/dev/null); then
		s+='$'
	fi

	[ -n "${s}" ] && s=" [${s}]"

	echo -e "branch ${branch_name} ${s}"
}

if [[ $COLORTERM = gnome-* && $TERM = xterm ]] && infocmp gnome-256color >/dev/null 2>&1
then
	export TERM='gnome-256color'
elif infocmp xterm-256color >/dev/null 2>&1
then
	export TERM='xterm-256color'
fi
case "$TERM" in
	xterm-color|*-256color) color_prompt=yes;;
esac

# default unset, to not distract user
#force_color_prompt=yes

if [ -n "$force_color_prompt" ]
then
	if [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null
	then
	# We have color support;
	# assume it's compliant with Ecma-48 (ISO/IEC-6429)
	# (Lack of such support is extremely rare,
	# and such a case would tend to support `setf` rather than `setaf`)
	color_prompt=yes
	else
	color_prompt=
	fi
fi

# common prefix
PS1='${debian_chroot:+($debian_chroot)}'

if [ "$color_prompt" = yes ]; then
	PS1+='\[\033[01;32m\]\u\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]'
else
	PS1+='\u:\w'
fi
unset color_prompt force_color_prompt

case "$TERM" in
xterm*|rxvt*)
	PS1="\[\e]0;${debian_chroot:+($debian_chroot)}\u: \w\a\]$PS1"
	;;
*)
	;;
esac

# common sufix
# (that wasn't a typo,
# "suffix" should have 1 "f", for consistency)
PS1+=" \$(prompt_git) \$ "

export PS1
