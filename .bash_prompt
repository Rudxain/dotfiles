#!/usr/bin/env bash

# I don't even use this, but I keep it just-in-case
if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]
then
	debian_chroot=$(cat /etc/debian_chroot)
fi

if [[ $COLORTERM = gnome-* && $TERM = xterm ]] && infocmp gnome-256color >/dev/null 2>&1
then
	export TERM='gnome-256color'
elif infocmp xterm-256color >/dev/null 2>&1
then
	export TERM='xterm-256color'
fi
case "$TERM" in
	xterm-color|*-256color) color_support=y;;
esac

if [ -z "${PREFIX:-}" ]; then
	pre_mut=y
	PREFIX=/usr
fi
if [ -x "$PREFIX/bin/tput" ] && tput setaf 1 &>/dev/null
then
	color_support=y
	tput sgr0 # is this necessary?
	RESET=$(tput sgr0)
	BLACK=$(tput setaf 0)
	RED=$(tput setaf 101)
	GREEN=$(tput setaf 102)
	YELLOW=$(tput setaf 103)
	BLUE=$(tput setaf 104)
	MAGENTA=$(tput setaf 105)
	CYAN=$(tput setaf 106)
	WHITE=$(tput setaf 107)
elif [ -n "${color_support:-}" ]; then
	RESET="\e[0m"
	BLACK="\e[1;30m"
	RED="\e[1;31m"
	GREEN="\e[1;32m"
	YELLOW="\e[1;33m"
	BLUE="\e[1;34m"
	MAGENTA="\e[1;35m"
	CYAN="\e[1;36m"
	WHITE="\e[1;37m"
fi
[ -n "${pre_mut:-}" ] && unset PREFIX

# common prefix
PS1='${debian_chroot:+($debian_chroot)}'
PS2=''

if [ -n "${color_support:-}" ]; then
	# to-do: try `rev`(7)
	PS1+="\[${GREEN}\]"
	PS2+="\[${MAGENTA}\]"
fi

if [ -z "${TERMUX_VERSION:-}" ]; then	
	PS1+='\u:'
fi
PS1+='\w'
PS2+='→ '

case "$TERM" in
xterm*|rxvt*)
	PS1="\[\e]0;${debian_chroot:+($debian_chroot)}\u: \w\a\]$PS1"
	;;
*)
	;;
esac

# this check saves energy if git isn't installed
if git --version &>/dev/null; then
	prompt_git() {
		git rev-parse --is-inside-work-tree &>/dev/null || return
		local s=''
		local branch_name=''

		branch_name="$(\
			git symbolic-ref --quiet --short HEAD 2> /dev/null || \
			git describe --all --exact-match HEAD 2> /dev/null || \
			git rev-parse --short HEAD 2> /dev/null || \
			echo '(?)' \
		)"

		# uncommitted
		if ! $(git diff --quiet --ignore-submodules --cached); then
			s+='+'
		fi
		# unstaged
		if ! $(git diff-files --quiet --ignore-submodules --); then
			s+='!'
		fi
		# untracked
		if [ -n "$(git ls-files --others --exclude-standard)" ]; then
			s+='?'
		fi
		# stashed
		if $(git rev-parse --verify refs/stash &>/dev/null); then
			s+='$'
		fi

		[ -n "${s}" ] && s=" [${s}]"

		echo -e " branch ${branch_name} ${s}"
	}
	PS1+="\$(prompt_git)"
fi

# common sufix (intentional typo)
PS1+=" \$ "
if [ -n "${color_support:-}" ]; then
	PS1+="\[${RESET}\]"
	PS2+="\[${RESET}\]"
fi
unset color_support
export PS1
export PS2
