root = true

[*]
charset = UTF-8
end_of_line = lf
indent_style = tab
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = false

# POSIX compliance
[.{bashrc,profile,aliases,fns,path,exports}]
insert_final_newline = true

[*.{,ba,b,da,k,mk}sh]
insert_final_newline = true

[.bash_*]
insert_final_newline = true

# `**` recursion is undesirable
[bin/*]
insert_final_newline = true
