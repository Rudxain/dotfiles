#!/bin/sh
set -uf # `e` is counter-prod

if [ -z "${TERMUX_VERSION:-}" ]
then
	# should I use apt-get?
	# "unstable API" doesn't seem to matter here
	if apt update && apt upgrade
	then
		apt autoclean
		apt autopurge

		npm update -g # for LSPs
	else
		rustup upgrade || exit $?

		# https://github.com/rust-lang/cargo/issues/9527
		crates="$(\
			cargo install --list |\
			# assume stable Cargo API
			grep -E '^[a-z0-9_-]+ v[0-9.]+:$' |\
			cut -f1 -d' ' \
		)"
		#shellcheck disable=SC2086
		[ -n "$crates" ] && cargo i $crates
	fi
else
	# https://wiki.termux.com/wiki/Package_Management
	if pkg upgrade
	then
		# I have backups, no worries
		pkg autoclean
		apt autopurge
	
		npm update -g # for LSPs
	fi
fi
