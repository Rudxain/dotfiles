#!/usr/bin/env bash
set -euf -o pipefail

#pkg upgrade # Termux
# should I use apt-get?
# it doesn't seem like "unstable API" matters here
apt update
apt upgrade

apt autoclean
apt autopurge

# if `apt` fails,
# it's very likely `npm` will also fail

# for LSPs
npm update -g || true

# Rust shouldn't care about `npm` failing

rustup upgrade
# the regex assumes the Cargo API is stable
readonly crates="$(cargo install --list | grep -E '^[a-z0-9_-]+ v[0-9.]+:$' | cut -f1 -d' ')"
[[ -n "$crates" ]] && cargo install $crates

# future: https://github.com/pypa/pip/issues/4551
