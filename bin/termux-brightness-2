#!/data/data/com.termux/files/usr/bin/bash
set -euf

readonly SCRIPTNAME=termux-brightness-2
usage="Usage: $SCRIPTNAME brightness"
usage+=$'\nSet the screen brightness between 0 and 8'

if [[ $# -ne 1 ]]; then
	echo "$usage"
	exit 0
fi

if ! [[ $1 =~ ^[0-8]$ ]]; then
	echo -e "ERROR: Arg must be an integer between 0 - 8 !\n$usage"
	exit 1
fi

readonly arg="$1"

# indirectly call `termux-api`,
# for forwards-compatibility
termux-brightness "$((~(-1 << arg)))"
