#!/usr/bin/env bash
set -eu
shopt -s nullglob

readonly DEF_T=15
if [[ $# -gt 0 ]]
then
	readonly period="$1"
else
	echo "using default period ${DEF_T}m"
	readonly period="$DEF_T"
fi

declare -a slide
update_slide ()
{
	if [[ $1 -eq 0 ]]
	then local -r mode=dark
	else local -r mode=light
	fi
	slide=("$EXTERNAL_STORAGE/Pictures/Wallpapers/$mode/"*)
	mapfile -t slide < <(shuf -e -- "${slide[@]}")
}

state_0=''
i=0
while true
do
	if termux-is-light-mode
	then state_1=1
	else state_1=0
	fi
	if [[ $state_0 != $state_1 ]]
	then
		state_0="$state_1"
		update_slide "$state_1"
		i=0
	fi
	termux-wallpaper-hl "${slide[i]}" > /dev/null
	sleep "${period}m"
	((i++))
done
