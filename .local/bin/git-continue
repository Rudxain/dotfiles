#!/usr/bin/env bash
set -eufo pipefail
IFS='
'

# https://github.com/tj/git-extras/blob/main/bin/git-continue

gitdir="$(git rev-parse --git-dir)"
readonly gitdir

discover_op() {
	local op
	for op in cherry_pick merge rebase revert; do
		if [ -f "$gitdir/${op^^}_HEAD" ]; then
			echo "${op/_/-}"
		fi
	done
}

validate_op() {
	if [ -z "$1" ]; then
		echo 'No active operation found' >&2
		exit 1
	fi
	if [ "$(echo "$1" | wc -l)" -gt 1 ]; then
		printf '%s\n' 'Multiple active operations found:' "$1" >&2
		exit 1
	fi
}

op=$(discover_op)
validate_op "$op"

#shellcheck disable=2086
git $op --continue
