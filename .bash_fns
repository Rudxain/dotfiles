#!/usr/bin/env bash

fs() {
	if du -b /dev/null > /dev/null 2>&1; then
		local -r arg=-sbh
	else
		local -r arg=-sh
	fi
	if [[ -n "$@" ]]; then
		du $arg -- "$@"
	else
		du $arg .[^.]* ./*
	fi
}

# password generator. usually meant for wifi A.P.s
keygen() {
	if [[ "$1" = wpa_main ]]
	then
		b16_rng 32 # max PSK size is 256b
		return
	fi
	if [[ "$1" = wpa_guest ]]
	then
		b16_rng 16 # guests need fast-to-type passwords
		return
	fi

	local len="$1"
	if [ -z "$len" ]
	then
		len=12 # good-enough entropy for most cases
	fi
	b64_rng "$len"
}
