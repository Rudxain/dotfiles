#!/bin/sh
alias reload='exec ${SHELL} -l'
alias sh='rlwrap -a sh'
alias dash='rlwrap -a dash'
alias bc='rlwrap -a bc'

alias paths='echo -e ${PATH//:/\\n}'

# the only thing MS did right /j
alias cls=clear

# raw strs
alias say="printf '%s\n'"

# Termux doesn't have the symlink
alias open=xdg-open

# safety
alias cp='cp -i'
alias mv='mv -i'
alias ln='ln -i'
alias rm='rm -i'

alias nuke='rm -rf --'

alias ..='cd ..'
alias ...='cd ../..'
alias ~='cd ~' # same as `cd` (0 args)?
alias -- -='cd -'

if [ -z "$TERMUX_VERSION" ]; then
	# I hate Samsung, but dex is a good short name
	alias cdex='cd ~/Desktop'
	alias cdl='cd ~/Downloads'

	alias cbg=wl-paste
	alias cbs=wl-copy
else
	# user home
	alias u~="cd $EXTERNAL_STORAGE"
	alias cdl='cd ~/downloads'
	alias cudl="cd $EXTERNAL_STORAGE/Download"

	alias cbg=termux-clipboard-get
	alias cbs=termux-clipboard-set
	alias cbtts='termux-clipboard-get | termux-tts-speak'
fi

# assume GNU flavor
flag='--color=auto'
if [ -x "$PREFIX/bin/dircolors" ]
then
	test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
	alias ls="ls $flag"
	alias dir="dir $flag"
	alias vdir="vdir $flag"

	# `GREP_OPTIONS="--color=auto"` is deprecated, hence these
	alias grep="grep $flag"
	alias fgrep="fgrep $flag"
	alias egrep="egrep $flag"
fi
unset flag

alias lal='ls -AlF'
alias la='ls -A'
alias lcf='ls -CF'
alias llf='ls -lF'
# list only directories
alias lsd="ls -lF | grep --color=never '^d'"

alias dusort='du -hd1 2>/dev/null | sort -h'

# canonicalize
command -v hd > /dev/null || alias hd='hexdump -C'
# some systems have this symlinked

# intuitive map fn
alias map='xargs -n1'
# is `grep` equivalent to `filter`?
# what about `fold`/`reduce`?
