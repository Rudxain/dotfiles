#!/bin/sh

mkcd() {
	#shellcheck disable=SC2164
	mkdir -p -- "$1" && cd -- "$1"
}

cdls() {
	cd -- "$1" && ls
}
cdla() {
	cd -- "$1" && ls -A
}

fs() {
	if [ "$#" -gt 0 ]; then
		du -sbh -- "$@"
	else
		# `--` is a micro-optimization.
		# these patterns work poorly with `failglob`.
		du -sbh -- .[!.]* ./* | sort -hr
	fi
}

loc1() {
	grep -rv '^\s*$' -- "$1" 2>/dev/null | wc -l
}

loc() {
	if [ $# -gt 0 ]; then
		for p in "$@"; do
			echo "$(loc1 "$p") $p"
		done
	else
		for p in .[!.]* ./*; do
			echo "$(loc1 "$p") $p"
		done | sort -nr
	fi
}
