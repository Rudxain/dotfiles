[core]
	# TIP: `git config feature.manyFiles true`
	# where appropriate
	untrackedCache = true # speed

[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[user]
	name = Rudxain
	email = 76864299+Rudxain@users.noreply.github.com
	# NOTE: `git config commit.gpgSign true`
	# in repos that I don't own
	signingkey = 0DAC837DDEF8E96C

[help]
	autoCorrect = prompt

[alias]
	aliases = config --get-regexp alias
	copy = clone --depth=1 # shallow
	c = commit
	cs = commit -S
	ca = commit -av
	cas = commit -avS
	l = log --pretty=oneline --graph --abbrev-commit
	s = status -s
	ss = status
	d = diff --name-only
	dd = diff
	statuses = branch -vv
	branches = branch -a
	tags = tag -l
	remotes = remote -v
	contributors = shortlog --summary --numbered
	# "GC"
	bdm = "!git branch --merged | grep -v '\\*' | xargs -rn1 git branch -d"
	rbi = "!r() { git rebase -i HEAD~$1; }; r"

[init]
	# solves racism across the entirety of space-time (/s):
	# https://sfconservancy.org/news/2020/jun/23/gitbranchname
	defaultBranch = main

[branch]
	sort = -committerdate # recent 1st

[color "branch"]
	current = reverse green
	local = green

[remote "origin"]
	prune = true

[url "https://github.com/"]
	insteadOf = "gh:"

[status]
	showStash = true

[diff]
	renames = copies
[diff "bin"]
	textconv = hexdump -v -C

[log]
	date = iso

[merge]
	# summarize commits
	log = true
	conflictStyle = zdiff3

[rebase]
	missingCommitsCheck = error
